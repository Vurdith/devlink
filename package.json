{
  "name": "devlink",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev --turbopack --port 3000",
    "build": "prisma generate && next build --turbopack",
    "postinstall": "prisma generate",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "k6 run loadtests/smoke.js",
    "test:load:messaging": "k6 run loadtests/messaging.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "analyze": "ANALYZE=true next build --turbopack",
    "tunnel": "npx cloudflared tunnel --url http://localhost:3000",
    "tunnel:dev": "concurrently \"npm run dev\" \"npm run tunnel\"",
    "kill": "taskkill /f /im node.exe & taskkill /f /im cloudflared.exe",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@next/bundle-analyzer": "^16.1.6",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "@sentry/nextjs": "^10.27.0",
    "@supabase/supabase-js": "^2.86.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@upstash/redis": "^1.34.3",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.13.3",
    "file-type": "^21.3.0",
    "framer-motion": "^12.34.3",
    "husky": "^9.1.7",
    "ioredis": "^5.4.2",
    "lint-staged": "^16.2.7",
    "lucide-react": "^0.575.0",
    "next": "^16.0.7",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.7",
    "otpauth": "^9.5.0",
    "otplib": "^13.3.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.4.1",
    "sanitize-html": "^2.17.1",
    "tailwind-merge": "^3.5.0"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed-skills.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^7.0.4",
    "@types/pg": "^8.15.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.9.19",
    "concurrently": "^9.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.0.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
